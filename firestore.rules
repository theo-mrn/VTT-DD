rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRoomMember(roomId) {
      return request.auth != null && userData().room_id == roomId;
    }

    function isRoomMJ(roomId) {
      return isRoomMember(roomId) && userData().perso == "MJ";
    }

    function isRoomPlayer(roomId) {
      return isRoomMember(roomId) && userData().perso != "MJ";
    }

    // Le joueur est propriétaire du personnage si persoId correspond
    function ownsCharacter(charId) {
      return request.auth != null && userData().persoId == charId;
    }

    // ── Profil utilisateur ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Salles (métadonnées) ───────────────────────────────────────────────────
    match /Salle/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.creatorId == request.auth.uid;

      // Systèmes de jeu personnalisés créés par le MJ (JSON pur, jamais de code exécutable) —
      // lecture ouverte à toute la table, écriture réservée au MJ.
      match /gameSystemOverrides/{systemId} {
        allow read: if isRoomMember(roomId);
        allow write: if isRoomMJ(roomId);

        // Contenu de jeu du système (voies, bestiaire, équipement...) — JSON pur, mêmes droits
        // que le système parent.
        match /content/{contentId} {
          allow read: if isRoomMember(roomId);
          allow write: if isRoomMJ(roomId);
        }
      }

      // Instances de l'entité de groupe (schéma GameSystemDefinition.groupEntityStats, nom libre défini
      // par le MJ — ex "Vaisseau", "Base secrète") — possédée par la table entière, pas par un personnage
      // individuel : lecture ouverte à toute la table, écriture réservée au MJ (même modèle que
      // gameSystemOverrides ci-dessus).
      match /groupEntities/{entityId} {
        allow read: if isRoomMember(roomId);
        allow write: if isRoomMJ(roomId);
      }
    }

    // ── Catalogue de systèmes de règles (partagé, indépendant d'une salle) ────
    // JSON pur (GameSystemDefinition sérialisé), jamais de code exécutable.
    // Lecture ouverte à tout utilisateur authentifié (ce ne sont que des règles de jeu,
    // pas des données sensibles) ; écriture réservée au créateur.
    match /gameSystems/{systemId} {
      // Lecture publique pour les systèmes marqués visibility 'public' (ex contenu dnd-classic seedé,
      // affiché sur les pages accessibles sans connexion comme /ressources) — sinon authentifié.
      allow read: if request.auth != null || resource.data.visibility == 'public';
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Contenu de jeu du système (voies, bestiaire, équipement...) — lecture ouverte comme le
      // système parent, écriture réservée à son créateur. Le contenu seedé (ex dnd-classic,
      // ownerId 'system' écrit par scripts/seed-game-content.mjs avec firebase-admin) est donc
      // en lecture seule côté client : un MJ duplique le système pour l'éditer.
      match /content/{contentId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/gameSystems/$(systemId)).data.ownerId == request.auth.uid;
      }
    }

    // ── Personnages ────────────────────────────────────────────────────────────
    // MJ : accès complet
    // Joueur : peut lire tous, éditer uniquement son propre perso (pas de création/suppression de PNJ)
    match /cartes/{roomId}/characters/{charId} {
      allow read: if isRoomMember(roomId);

      // Création : MJ uniquement (les joueurs ne créent pas de PNJ)
      allow create: if isRoomMJ(roomId);

      // Mise à jour : MJ ou joueur propriétaire du perso
      allow update: if isRoomMJ(roomId)
        || (isRoomPlayer(roomId) && ownsCharacter(charId));

      // Suppression : MJ uniquement
      allow delete: if isRoomMJ(roomId);
    }

    // ── Zones réservées au MJ (carte, décor, ambiance) ────────────────────────
    // cities, fog, musicZones, portals, settings, scenario, objects, lights
    // (measurements a été migré en RTDB, voir database.rules.json)
    match /cartes/{roomId}/cities/{document=**} {
      allow read: if isRoomMember(roomId);
      allow write: if isRoomMJ(roomId);
    }

    match /cartes/{roomId}/fog/{document=**} {
      allow read: if isRoomMember(roomId);
      allow write: if isRoomMJ(roomId);
    }

    match /cartes/{roomId}/musicZones/{document=**} {
      allow read: if isRoomMember(roomId);
      allow write: if isRoomMJ(roomId);
    }

    match /cartes/{roomId}/portals/{document=**} {
      allow read: if isRoomMember(roomId);
      allow write: if isRoomMJ(roomId);
    }

    match /cartes/{roomId}/settings/{document=**} {
      allow read: if isRoomMember(roomId);
      allow write: if isRoomMJ(roomId);
    }

    match /cartes/{roomId}/objects/{document=**} {
      allow read: if isRoomMember(roomId);
      allow write: if isRoomMJ(roomId);
    }

    match /cartes/{roomId}/lights/{document=**} {
      allow read: if isRoomMember(roomId);
      allow write: if isRoomMJ(roomId);
    }

    match /cartes/{roomId}/fond/{document=**} {
      allow read: if isRoomMember(roomId);
      allow write: if isRoomMJ(roomId);
    }

    // ── Combat (rapports d'attaque) — MJ + joueurs ────────────────────────────
    match /cartes/{roomId}/combat/{document=**} {
      allow read: if isRoomMember(roomId);
      allow write: if isRoomMJ(roomId) || isRoomPlayer(roomId);
    }

    // ── Document racine de la room (currentMusic, etc.) ───────────────────────
    match /cartes/{roomId} {
      allow read: if isRoomMember(roomId);
      allow write: if isRoomMJ(roomId);
    }

    // ── Jets de dés ───────────────────────────────────────────────────────────
    match /rolls/{roomId}/{document=**} {
      allow read, write: if isRoomMember(roomId);
    }

    // ── Inventaire ────────────────────────────────────────────────────────────
    match /Inventaire/{roomId}/{document=**} {
      allow read, write: if isRoomMember(roomId);
    }

    // ── Bonus ─────────────────────────────────────────────────────────────────
    match /Bonus/{roomId}/{document=**} {
      allow read, write: if isRoomMember(roomId);
    }

    // ── Historique ────────────────────────────────────────────────────────────
    match /Historique/{roomId}/{document=**} {
      allow read, write: if isRoomMember(roomId);
    }

    // ── Notes ─────────────────────────────────────────────────────────────────
    match /Notes/{roomId}/{document=**} {
      allow read, write: if isRoomMember(roomId);
    }

    match /SharedNotes/{roomId}/{document=**} {
      allow read, write: if isRoomMember(roomId);
    }
  }
}
